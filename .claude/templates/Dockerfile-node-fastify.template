# syntax=docker/dockerfile:1.7
#
# Dockerfile for apps/api/ (node-fastify stack).
# Copied verbatim by /architect step 11 — do not hand-edit the project copy;
# re-run /architect to regenerate. Project-level customisation (extra
# build steps, package installs, etc.) belongs in a docker-compose override.
#
# Build context: project root (docker-compose.yml sets context: .).
# Final image: ~150-200MB on Alpine; runs apps/api/src/server.ts via tsx.

FROM node:22-alpine AS base
RUN corepack enable && corepack prepare pnpm@9 --activate
WORKDIR /app

# ─── Stage 1: install workspace deps (cached layer) ────────────────────────
# Copy ONLY package manifests + lockfile first so Docker layer-caches the
# install step. Source changes don't bust this layer.
FROM base AS deps
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml turbo.json tsconfig.json ./
COPY apps/api/package.json apps/api/
COPY packages packages/
RUN pnpm install --frozen-lockfile --filter @repo/api...

# ─── Stage 2: runtime ──────────────────────────────────────────────────────
FROM base AS runtime
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/apps/api/node_modules ./apps/api/node_modules
COPY --from=deps /app/packages ./packages
COPY pnpm-workspace.yaml package.json turbo.json tsconfig.json ./
COPY apps/api apps/api/

# tsx watches src/server.ts in dev; node-prod stacks should swap this for
# a real compile step + `node dist/server.js`. Curriculum projects keep
# the dev shape for parity with `pnpm dev`.
ENV NODE_ENV=production
EXPOSE 3001
HEALTHCHECK --interval=10s --timeout=3s --start-period=15s --retries=5 \
  CMD wget --quiet --tries=1 --spider http://localhost:3001/health || exit 1

CMD ["pnpm", "--filter", "@repo/api", "start"]

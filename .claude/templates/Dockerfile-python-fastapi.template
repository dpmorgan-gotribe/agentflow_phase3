# syntax=docker/dockerfile:1.7
#
# Dockerfile for apps/api/ (python-fastapi stack).
# Copied verbatim by /architect step 11.
#
# Uses uv for fast deterministic installs; binds canonical entry at
# apps/api/src/api/main.py (PROTECTED per bug-111).

FROM python:3.12-slim AS base
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl ca-certificates \
  && rm -rf /var/lib/apt/lists/* \
  && pip install --no-cache-dir uv
WORKDIR /app

# ─── Stage 1: deps ─────────────────────────────────────────────────────────
FROM base AS deps
COPY apps/api/pyproject.toml apps/api/uv.lock* apps/api/
WORKDIR /app/apps/api
RUN uv sync --frozen --no-dev || uv sync --no-dev

# ─── Stage 2: runtime ──────────────────────────────────────────────────────
FROM base AS runtime
COPY --from=deps /app/apps/api/.venv /app/apps/api/.venv
WORKDIR /app
COPY apps/api apps/api/

ENV PATH="/app/apps/api/.venv/bin:$PATH"
ENV PYTHONUNBUFFERED=1
EXPOSE 8000
HEALTHCHECK --interval=10s --timeout=3s --start-period=15s --retries=5 \
  CMD curl -fsS http://localhost:8000/health || exit 1

WORKDIR /app/apps/api
CMD ["uv", "run", "uvicorn", "api.main:app", "--host", "0.0.0.0", "--port", "8000"]

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BuildToSpecVerifyOutput",
  "type": "object",
  "properties": {
    "ok": {
      "type": "boolean"
    },
    "reachability": {
      "type": "object",
      "properties": {
        "orphanComponents": {
          "default": [],
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1
              },
              "exportNames": {
                "default": [],
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "owningFeature": {
                "anyOf": [
                  {
                    "type": "string",
                    "pattern": "^feat-[a-z][a-z0-9-]{1,48}$"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "suggestedImporters": {
                "default": [],
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "reason": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "path",
              "exportNames",
              "owningFeature",
              "suggestedImporters",
              "reason"
            ],
            "additionalProperties": false
          }
        },
        "orphanRoutes": {
          "default": [],
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1
              },
              "routePattern": {
                "type": "string",
                "minLength": 1
              },
              "owningFeature": {
                "anyOf": [
                  {
                    "type": "string",
                    "pattern": "^feat-[a-z][a-z0-9-]{1,48}$"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "suggestedNavSurfaces": {
                "default": [],
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "reason": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "path",
              "routePattern",
              "owningFeature",
              "suggestedNavSurfaces",
              "reason"
            ],
            "additionalProperties": false
          }
        },
        "scannedFiles": {
          "default": 0,
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "ignoredByAllowComment": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "orphanComponents",
        "orphanRoutes",
        "scannedFiles",
        "ignoredByAllowComment"
      ],
      "additionalProperties": false
    },
    "flows": {
      "type": "object",
      "properties": {
        "passed": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "failed": {
          "default": [],
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "flowId": {
                "type": "string",
                "minLength": 1
              },
              "flowName": {
                "type": "string",
                "minLength": 1
              },
              "step": {
                "type": "integer",
                "minimum": 0,
                "maximum": 9007199254740991
              },
              "fromScreenId": {
                "type": "string",
                "minLength": 1
              },
              "expectedScreenId": {
                "type": "string",
                "minLength": 1
              },
              "actualScreenId": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "selector": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "screenshotPath": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "htmlDumpPath": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "screenshot": {
                "type": "string"
              },
              "html": {
                "type": "string"
              },
              "runtimeErrors": {
                "type": "object",
                "properties": {
                  "consoleErrors": {
                    "default": [],
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "pageErrors": {
                    "default": [],
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "message": {
                          "type": "string",
                          "minLength": 1
                        },
                        "stack": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "message"
                      ],
                      "additionalProperties": false
                    }
                  },
                  "networkFailures": {
                    "default": [],
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "method": {
                          "type": "string",
                          "minLength": 1
                        },
                        "url": {
                          "type": "string",
                          "minLength": 1
                        },
                        "failureText": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "method",
                        "url",
                        "failureText"
                      ],
                      "additionalProperties": false
                    }
                  },
                  "devServerOverlay": {
                    "type": "object",
                    "properties": {
                      "rawText": {
                        "type": "string",
                        "minLength": 1
                      },
                      "detected": {
                        "type": "boolean"
                      }
                    },
                    "required": [
                      "rawText",
                      "detected"
                    ],
                    "additionalProperties": false
                  }
                },
                "required": [
                  "consoleErrors",
                  "pageErrors",
                  "networkFailures"
                ],
                "additionalProperties": false
              },
              "primaryCause": {
                "type": "string",
                "enum": [
                  "step-transition",
                  "runtime-error",
                  "dev-server-compile",
                  "timeout-no-evidence",
                  "seed-setup"
                ]
              },
              "message": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "flowId",
              "flowName",
              "step",
              "fromScreenId",
              "expectedScreenId",
              "actualScreenId",
              "selector",
              "screenshotPath",
              "htmlDumpPath",
              "message"
            ],
            "additionalProperties": false
          }
        },
        "generated": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "passed",
        "failed",
        "generated"
      ],
      "additionalProperties": false
    },
    "parity": {
      "type": "object",
      "properties": {
        "ok": {
          "type": "boolean"
        },
        "screensChecked": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "divergences": {
          "default": [],
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "screen": {
                "type": "string",
                "minLength": 1
              },
              "pattern": {
                "type": "string",
                "enum": [
                  "shell-stripping",
                  "layout-regrouping",
                  "token-drift",
                  "copy-sizing-drift",
                  "spacing-token-drift",
                  "identity-contract-broken",
                  "uncategorized"
                ]
              },
              "detail": {
                "type": "object",
                "properties": {
                  "missing": {
                    "default": [],
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "extra": {
                    "default": [],
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "variantDrift": {
                    "default": [],
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "selector": {
                          "type": "string",
                          "minLength": 1
                        },
                        "mockupValue": {
                          "type": "string"
                        },
                        "builtValue": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "selector",
                        "mockupValue",
                        "builtValue"
                      ],
                      "additionalProperties": false
                    }
                  },
                  "styleDrift": {
                    "default": [],
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "selector": {
                          "type": "string",
                          "minLength": 1
                        },
                        "property": {
                          "type": "string",
                          "minLength": 1
                        },
                        "mockupValue": {
                          "type": "string"
                        },
                        "builtValue": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "selector",
                        "property",
                        "mockupValue",
                        "builtValue"
                      ],
                      "additionalProperties": false
                    }
                  }
                },
                "required": [
                  "missing",
                  "extra",
                  "variantDrift",
                  "styleDrift"
                ],
                "additionalProperties": false
              },
              "severity": {
                "default": "P1",
                "type": "string",
                "enum": [
                  "P0",
                  "P1",
                  "P2"
                ]
              }
            },
            "required": [
              "screen",
              "pattern",
              "detail",
              "severity"
            ],
            "additionalProperties": false
          }
        },
        "warnings": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "durationMs": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "costUsd": {
          "type": "number",
          "minimum": 0
        }
      },
      "required": [
        "ok",
        "screensChecked",
        "divergences",
        "warnings",
        "durationMs",
        "costUsd"
      ],
      "additionalProperties": false
    },
    "bugPlansFiled": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "costUsd": {
      "type": "number",
      "minimum": 0
    },
    "durationMs": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "warnings": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "ok",
    "reachability",
    "flows",
    "bugPlansFiled",
    "costUsd",
    "durationMs",
    "warnings"
  ],
  "additionalProperties": false
}